<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PROCORE | Lecciones Aprendidas</title>
 
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
 
<style>

body{

    background:#1f1f1f;

    color:white;

    font-family:Segoe UI;

    margin:0;

}
 
.header{

    background:#16304f;

    padding:20px;

    font-size:28px;

    font-weight:bold;

}
 
.container{

    padding:20px;

}
 
.cards{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:15px;

}
 
.card{

    background:#2a2a2a;

    border-radius:10px;

    padding:20px;

}
 
.valor{

    font-size:38px;

    font-weight:bold;

}
 
.green{

    color:#43a047;

}
 
.red{

    color:#e53935;

}
 
.white{

    color:white;

}
 
.grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:20px;

    margin-top:20px;

}
 
.chart-container{

    background:#2a2a2a;

    border-radius:10px;

    padding:20px;

}
 
.formulario{

    margin-top:25px;

    background:#2a2a2a;

    border-radius:10px;

    padding:20px;

}
 
input,select,textarea{

    width:100%;

    padding:10px;

    margin-top:5px;

    margin-bottom:15px;

    border:none;

    border-radius:5px;

}
 
button{

    background:#1976d2;

    color:white;

    border:none;

    padding:12px 20px;

    border-radius:5px;

    cursor:pointer;

}
 
table{

    width:100%;

    margin-top:20px;

    border-collapse:collapse;

}
 
th,td{

    border:1px solid #444;

    padding:10px;

}
 
th{

    background:#16304f;

}
</style>
 
</head>
 
<body>
 
<div class="header">

PROCORE | Lecciones Aprendidas - Impacto Kaizen
</div>
 
<div class="container">
 
<div class="cards">
 
<div class="card">

Ahorros acumulados
<div class="valor green">$284,500</div>
</div>
 
<div class="card">

Costos de falla
<div class="valor red">$97,200</div>
</div>
 
<div class="card">

Lecciones registradas
<div class="valor white" id="totalRegistros">0</div>
</div>
 
<div class="card">

Impacto neto
<div class="valor green">$187,300</div>
</div>
 
</div>
 
<div class="grid">
 
<div class="chart-container">
<canvas id="grafica1"></canvas>
</div>
 
<div class="chart-container">
<canvas id="grafica2"></canvas>
</div>
 
</div>
 
<div class="formulario">
 
<h2>Registrar Lección Aprendida</h2>
 
<label>Tipo de Registro</label>
<select id="tipo">
<option>Falla</option>
<option>Lección Aprendida</option>
<option>Buena Práctica</option>
<option>Retrabajo</option>
<option>Observación</option>
</select>
 
<label>Proyecto</label>
<input id="proyecto">
 
<label>Departamento</label>
<select id="departamento">
<option>Producción</option>
<option>Ingeniería HVAC</option>
<option>Ingeniería F&P</option>
<option>Compras</option>
<option>Calidad</option>
<option>Procesos</option>
<option>RH</option>
</select>
 
<label>Descripción</label>
<textarea id="descripcion"></textarea>
 
<label>Monto MXN</label>
<input type="number" id="monto">
 
<button onclick="guardarRegistro()">

Guardar Registro
</button>
 
</div>
 
<table>
 
<thead>
<tr>
<th>Tipo</th>
<th>Proyecto</th>
<th>Departamento</th>
<th>Monto</th>
<th>Descripción</th>
</tr>
</thead>
 
<tbody id="tablaRegistros">
 
</tbody>
 
</table>
 
</div>
 
<script>
 
let registros=[];
 
function guardarRegistro(){
 
const registro={

tipo:document.getElementById('tipo').value,

proyecto:document.getElementById('proyecto').value,

departamento:document.getElementById('departamento').value,

monto:document.getElementById('monto').value,

descripcion:document.getElementById('descripcion').value

};
 
registros.push(registro);
 
actualizarTabla();
 
document.getElementById("totalRegistros").innerText=registros.length;

}
 
function actualizarTabla(){
 
let html="";
 
registros.forEach(r=>{
 
html+=`
<tr>
<td>${r.tipo}</td>
<td>${r.proyecto}</td>
<td>${r.departamento}</td>
<td>$${r.monto}</td>
<td>${r.descripcion}</td>
</tr>

`;
 
});
 
document.getElementById("tablaRegistros").innerHTML=html;
 
}
 
new Chart(document.getElementById('grafica1'),{

type:'bar',

data:{

labels:['Ene','Feb','Mar','Abr','May','Jun'],

datasets:[

{

label:'Ahorro',

data:[30,40,38,55,62,57],

backgroundColor:'green'

},

{

label:'Costo de falla',

data:[28,22,18,14,9,6],

backgroundColor:'red'

}

]

}

});
 
new Chart(document.getElementById('grafica2'),{

type:'doughnut',

data:{

labels:[

'Falla',

'Lección Aprendida',

'Buena Práctica',

'Retrabajo',

'Observación'

],

datasets:[{

data:[12,18,25,8,5]

}]

}

});
 
</script>
 
</body>
</html>
